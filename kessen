<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kessen - คมศาสตราและจิตวิญญาณบูชิโด</title>
    <!-- Google Fonts: Sarabun สำหรับภาษาไทย และ Montserrat สำหรับสไตล์พรีเมียม -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,500;0,700;0,900;1,300&family=Sarabun:wght@200;400;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome สำหรับไอคอน -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ==========================================
           RESET & CSS VARIABLES
           ========================================== */
        :root {
            --primary: #E50914; /* แดงสว่างเด่นชัด */
            --primary-dark: #8B0000; /* แดงเข้มลุ่มลึก */
            --bg-dark: #0a0a0a; /* ดำสนิท */
            --bg-card: #141414; /* ดำเทาสำหรับการ์ด */
            --text-light: #ffffff; /* ขาวสะอาด */
            --text-gray: #b3b3b3; /* เทาอ่านง่าย */
            --glass: rgba(20, 20, 20, 0.75);
            --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.5);
            --shadow-lg: 0 10px 30px rgba(0,0,0,0.8);
            --border-radius: 12px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Sarabun', 'Montserrat', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            line-height: 1.6;
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        img {
            max-width: 100%;
            height: auto;
            display: block;
        }

        /* Container กำหนดขอบเขต */
        .container {
            width: 90%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 15px;
        }

        /* ==========================================
           NAVIGATION BAR (Glassmorphism)
           ========================================== */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background: var(--glass);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
        }

        header.scrolled {
            background: rgba(10, 10, 10, 0.95);
            padding: 5px 0;
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-img {
            width: 45px;
            height: 45px;
            object-fit: contain;
            border-radius: 50%;
            border: 2px solid var(--primary);
            box-shadow: 0 0 10px rgba(229, 9, 20, 0.3);
        }

        .logo-text {
            font-family: 'Montserrat', sans-serif;
            font-size: 24px;
            font-weight: 900;
            letter-spacing: 2px;
            color: var(--text-light);
            text-transform: uppercase;
        }

        .logo-text span {
            color: var(--primary);
        }

        .nav-menu {
            display: flex;
            gap: 30px;
            list-style: none;
        }

        .nav-link {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-gray);
            transition: var(--transition);
            position: relative;
            padding: 5px 0;
        }

        .nav-link:hover, .nav-link.active {
            color: var(--primary);
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background-color: var(--primary);
            transition: var(--transition);
        }

        .nav-link:hover::after, .nav-link.active::after {
            width: 100%;
        }

        /* Hamburger Menu สำหรับหน้าจอมือถือ */
        .hamburger {
            display: none;
            cursor: pointer;
            background: none;
            border: none;
            color: var(--text-light);
            font-size: 24px;
        }

        /* ==========================================
           HERO SECTION
           ========================================== */
        .hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(180deg, rgba(10,10,10,0.4) 0%, rgba(10,10,10,0.95) 100%), 
                        url('https://share.google/XyUX8BttnbBgIPBd5') center/cover no-repeat;
            /* Fallback background หากลิ้งก์โหลดไม่ได้ */
            background-color: #111;
            text-align: center;
            padding-top: 80px;
        }

        /* เพิ่ม Overlay ลวดลายญี่ปุ่นบางๆ หรือการไล่เฉดสี */
        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, transparent 20%, rgba(10,10,10,0.8) 100%);
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 800px;
            padding: 20px;
            opacity: 0;
            transform: translateY(30px);
            animation: fadeInUp 1.2s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }

        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero-title {
            font-family: 'Montserrat', 'Sarabun', sans-serif;
            font-size: 64px;
            font-weight: 900;
            letter-spacing: 4px;
            margin-bottom: 15px;
            text-transform: uppercase;
            text-shadow: 0 4px 20px rgba(0,0,0,0.6);
        }

        .hero-title span {
            color: var(--primary);
            position: relative;
        }

        .hero-slogan {
            font-size: 22px;
            font-weight: 400;
            color: #f1f1f1;
            margin-bottom: 35px;
            letter-spacing: 1px;
            border-left: 3px solid var(--primary);
            border-right: 3px solid var(--primary);
            display: inline-block;
            padding: 0 20px;
            text-shadow: 0 2px 10px rgba(0,0,0,0.5);
        }

        .btn-cta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background-color: var(--primary);
            color: var(--text-light);
            padding: 15px 35px;
            font-size: 16px;
            font-weight: 700;
            border-radius: var(--border-radius);
            box-shadow: 0 4px 15px rgba(229, 9, 20, 0.4);
            transition: var(--transition);
            border: none;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-cta:hover {
            background-color: var(--primary-dark);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(229, 9, 20, 0.6);
        }

        /* Scroll Down Indicator */
        .scroll-down {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 2;
            color: var(--text-gray);
            font-size: 24px;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translate(-50%, 0); }
            40% { transform: translate(-50%, -10px); }
            60% { transform: translate(-50%, -5px); }
        }

        /* ==========================================
           ABOUT SECTION (เกี่ยวกับเรา)
           ========================================== */
        .section {
            padding: 100px 0;
            position: relative;
        }

        .section-header {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-subtitle {
            color: var(--primary);
            text-transform: uppercase;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 3px;
            margin-bottom: 10px;
            display: block;
        }

        .section-title {
            font-size: 36px;
            font-weight: 700;
            position: relative;
            display: inline-block;
            padding-bottom: 15px;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 3px;
            background-color: var(--primary);
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }

        .about-content {
            font-size: 16px;
            color: var(--text-gray);
            line-height: 1.8;
        }

        .about-content p {
            margin-bottom: 20px;
        }

        .about-highlight {
            border-left: 4px solid var(--primary);
            padding-left: 20px;
            font-style: italic;
            color: var(--text-light);
            font-size: 18px;
            margin: 25px 0;
        }

        .about-visual {
            position: relative;
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--shadow-lg);
        }

        .about-visual::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(45deg, rgba(229,9,20,0.2) 0%, transparent 100%);
            z-index: 1;
        }

        .about-img {
            width: 100%;
            height: 400px;
            object-fit: cover;
            transition: var(--transition);
        }

        .about-visual:hover .about-img {
            transform: scale(1.05);
        }

        /* ==========================================
           PRODUCT SECTION & CATEGORY FILTER
           ========================================== */
        .product-section {
            background-color: #0f0f0f;
        }

        .filter-container {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 50px;
        }

        .filter-btn {
            background-color: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.1);
            color: var(--text-gray);
            padding: 10px 24px;
            font-size: 14px;
            font-weight: 600;
            border-radius: 30px;
            cursor: pointer;
            transition: var(--transition);
        }

        .filter-btn:hover, .filter-btn.active {
            background-color: var(--primary);
            color: var(--text-light);
            border-color: var(--primary);
            box-shadow: 0 4px 12px rgba(229, 9, 20, 0.3);
        }

        /* Grid Layout */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 30px;
        }

        /* Card สินค้า */
        .product-card {
            background-color: var(--bg-card);
            border-radius: var(--border-radius);
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            height: 100%;
            position: relative;
        }

        .product-card:hover {
            transform: translateY(-10px);
            border-color: rgba(229, 9, 20, 0.3);
            box-shadow: 0 12px 30px rgba(0,0,0,0.6), 0 0 15px rgba(229,9,20,0.1);
        }

        .product-img-wrapper {
            position: relative;
            width: 100%;
            height: 250px;
            overflow: hidden;
            background-color: #1a1a1a;
        }

        .product-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition);
        }

        .product-card:hover .product-img {
            transform: scale(1.08);
        }

        .product-tag {
            position: absolute;
            top: 15px;
            right: 15px;
            background-color: rgba(10, 10, 10, 0.85);
            border-left: 3px solid var(--primary);
            color: var(--text-light);
            padding: 5px 12px;
            font-size: 11px;
            font-weight: 700;
            border-radius: 4px;
            text-transform: uppercase;
            backdrop-filter: blur(4px);
        }

        .product-info {
            padding: 22px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .product-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 10px;
            color: var(--text-light);
            min-height: 54px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-price {
            font-family: 'Montserrat', sans-serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 20px;
        }

        .product-price span {
            font-size: 14px;
            color: var(--text-gray);
            font-weight: 400;
            margin-left: 2px;
        }

        .btn-buy {
            background-color: transparent;
            border: 2px solid var(--primary);
            color: var(--text-light);
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: auto;
        }

        .btn-buy:hover {
            background-color: var(--primary);
            box-shadow: 0 4px 15px rgba(229, 9, 20, 0.4);
        }

        /* Animation class สำหรับการกรอง */
        .product-card.hide {
            display: none;
        }

        .product-card.show {
            animation: popIn 0.4s ease forwards;
        }

        @keyframes popIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* ==========================================
           CONTACT SECTION (ติดต่อเรา)
           ========================================== */
        .contact-section {
            background: linear-gradient(180deg, #0f0f0f 0%, #050505 100%);
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 50px;
        }

        .contact-info-card {
            background-color: var(--bg-card);
            border-radius: var(--border-radius);
            padding: 40px;
            border: 1px solid rgba(255,255,255,0.03);
            box-shadow: var(--shadow-lg);
        }

        .contact-text {
            color: var(--text-gray);
            margin-bottom: 35px;
            font-size: 16px;
        }

        .contact-method-list {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .contact-item {
            display: flex;
            align-items: flex-start;
            gap: 20px;
        }

        .contact-icon {
            width: 50px;
            height: 50px;
            background-color: rgba(229, 9, 20, 0.1);
            border: 1px solid rgba(229, 9, 20, 0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 20px;
            flex-shrink: 0;
            transition: var(--transition);
        }

        .contact-item:hover .contact-icon {
            background-color: var(--primary);
            color: var(--text-light);
            transform: scale(1.1);
        }

        .contact-detail h4 {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .contact-detail p, .contact-detail a {
            color: var(--text-gray);
            font-size: 15px;
            transition: var(--transition);
        }

        .contact-detail a:hover {
            color: var(--primary);
        }

        /* Quick Contact Form */
        .contact-form {
            background-color: rgba(20, 20, 20, 0.5);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 40px;
            border-radius: var(--border-radius);
        }

        .form-title {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 25px;
            border-bottom: 2px solid var(--primary);
            padding-bottom: 10px;
            display: inline-block;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--text-gray);
        }

        .form-control {
            width: 100%;
            background-color: #0d0d0d;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 12px 15px;
            color: var(--text-light);
            font-family: inherit;
            font-size: 15px;
            transition: var(--transition);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 8px rgba(229, 9, 20, 0.25);
        }

        .btn-submit {
            width: 100%;
            background-color: var(--primary);
            color: var(--text-light);
            padding: 14px;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
        }

        .btn-submit:hover {
            background-color: var(--primary-dark);
            box-shadow: 0 4px 15px rgba(229, 9, 20, 0.3);
        }

        /* ==========================================
           FOOTER (ส่วนท้ายเว็บ)
           ========================================== */
        footer {
            background-color: #050505;
            padding: 50px 0 20px 0;
            border-top: 1px solid rgba(255,255,255,0.03);
            color: var(--text-gray);
            font-size: 14px;
        }

        .footer-grid {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 25px;
          
